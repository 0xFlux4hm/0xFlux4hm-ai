# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Framework Configuration
FRAMEWORK_ENV=production
DEBUG_MODE=false

# Database Configuration
DATABASE_URL=sqlite:///./0xfluxhunter.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/0xfluxhunter

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/0xfluxhunter.log

# Security Configuration
ALLOW_DESTRUCTIVE_PAYLOADS=false
ENFORCE_ETHICAL_BOUNDARIES=true

# Tool Configuration
TIMEOUT_SECONDS=300
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Memory Configuration
MAX_MEMORY_ITEMS=10000
MEMORY_PERSISTENCE=true
